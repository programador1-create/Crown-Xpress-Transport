{
  "version": 2,
  "functions": {
    "api/**/*.js": {
      "maxDuration": 30,
      "memory": 1024
    }
  },
  "buildCommand": "npm run build",
  "outputDirectory": "dist",
  "rewrites": [
    {
      "source": "/api/inspections",
      "destination": "/api/inspections/index.js"
    },
    {
      "source": "/api/inspections/:id",
      "destination": "/api/inspections/[id].js"
    },
    {
      "source": "/api/inspections/:id/pdf",
      "destination": "/api/inspections/[id].js"
    },
    {
      "source": "/api/inspections/:id/sign-supervisor",
      "destination": "/api/inspections/[id].js"
    },
    {
      "source": "/api/employees",
      "destination": "/api/employees.js"
    },
    {
      "source": "/api/auth",
      "destination": "/api/auth.js"
    },
    {
      "source": "/(.*)",
      "destination": "/index.html"
    }
  ]
}
