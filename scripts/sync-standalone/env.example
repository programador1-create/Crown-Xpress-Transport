# SQL Server NBCW (origen)
SQLSERVER_HOST=192.168.5.13
# Usa SQLSERVER_PORT para conectar directo por TCP (recomendado).
# Si lo dejas vacio, usa SQLSERVER_INSTANCE (requiere SQL Server Browser).
SQLSERVER_PORT=1433
# SQLSERVER_INSTANCE=BKUPEXEC
SQLSERVER_DATABASE=GPSActivity
SQLSERVER_USER=sa
SQLSERVER_PASSWORD=TU_PASSWORD

# Neon PostgreSQL (destino)
DATABASE_URL=postgres://usuario:password@host.neon.tech/neondb?sslmode=require

# Idioma de fecha de SQL Server: MDY (mes/dia/año) o DMY (dia/mes/año)
# Si el servidor Windows/SQL Server esta en español, prueba con DMY.
SQLSERVER_DATE_FORMAT=MDY

# Cuantos dias hacia atras sincronizar
TPR_SYNC_DAYS=30

