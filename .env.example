# ============================================================
# Crown Xpress Transport - Environment Variables
# Copy this file to .env and fill in the values
# ============================================================

# Neon Postgres connection string
# Get yours at https://console.neon.tech
# Use the "Pooled connection" URL (recommended for serverless)
DATABASE_URL=postgresql://user:password@ep-xxx-pooler.region.aws.neon.tech/dbname?sslmode=require

# Server (local development)
API_PORT=3001

# Vite (frontend) - proxy target
# Leave default unless you changed API_PORT
VITE_API_URL=/api
